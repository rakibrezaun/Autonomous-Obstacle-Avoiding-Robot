#include <Servo.h>
#include <NewPing.h>

#define SERVO_PIN 3
#define TRIG_PIN 11
#define ECHO_PIN 12

#define ENA 5
#define IN1 7
#define IN2 8

#define ENB 6
#define IN3 9
#define IN4 10

#define MAX_DISTANCE 200
#define SAFE_DISTANCE 25
#define NORMAL_SPEED 80
#define TURN_SPEED 150

NewPing sonar(TRIG_PIN, ECHO_PIN, MAX_DISTANCE);
Servo servoMotor;

int distanceFront, distanceLeft, distanceRight;

void setup() {
  pinMode(ENA, OUTPUT);
  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);

  pinMode(ENB, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);

  servoMotor.attach(SERVO_PIN);
  servoMotor.write(90);

  stopMotors();
}

void loop() {
  distanceFront = getDistance();

  if (distanceFront < SAFE_DISTANCE && distanceFront > 0) {
    avoidObstacle();
  } else {
    moveForward(NORMAL_SPEED);
  }
}


int getDistance() {
  delay(30);
  int d = sonar.ping_cm();
  if (d == 0) d = 250;  // treat 0 as "no obstacle"
  return d;
}

void avoidObstacle() {
  stopMotors();
  delay(200);

  moveBackward(TURN_SPEED);
  delay(300);

  stopMotors();
  delay(200);

  servoMotor.write(160);
  delay(400);
  distanceLeft = getDistance();

  servoMotor.write(20);
  delay(400);
  distanceRight = getDistance();

  servoMotor.write(90);

  if (distanceLeft > distanceRight) {
    turnLeft(TURN_SPEED);
  } else {
    turnRight(TURN_SPEED);
  }

  delay(300);
}


void moveForward(int speed) {
  setMotor(speed, speed);
}

void moveBackward(int speed) {
  setMotor(-speed, -speed);
}

void turnLeft(int speed) {
  setMotor(-speed, speed);
}

void turnRight(int speed) {
  setMotor(speed, -speed);
}

void stopMotors() {
  setMotor(0, 0);
}

void setMotor(int rightSpeed, int leftSpeed) {
  digitalWrite(IN1, rightSpeed >= 0);
  digitalWrite(IN2, rightSpeed < 0);

  digitalWrite(IN3, leftSpeed >= 0);
  digitalWrite(IN4, leftSpeed < 0);

  analogWrite(ENA, abs(rightSpeed));
  analogWrite(ENB, abs(leftSpeed));
}
